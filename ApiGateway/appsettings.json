{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "ReverseProxy": {
    "Routes": {
      "auth-swagger": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/api/users/swagger/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/api/users" }]
      },
      "room-swagger": {
        "ClusterId": "room-cluster",
        "Match": { "Path": "/api/rooms/swagger/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/api/rooms" }]
      },
      "message-swagger": {
        "ClusterId": "message-cluster",
        "Match": { "Path": "/api/messages/swagger/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/api/messages" }]
      },
      "notification-swagger": {
        "ClusterId": "notification-cluster",
        "Match": { "Path": "/api/notifications/swagger/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/api/notifications" }]
      },
      "media-swagger": {
        "ClusterId": "media-cluster",
        "Match": { "Path": "/api/media/swagger/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/api/media" }]
      },
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/api/users/{**catch-all}" }
      },
      "auth-admin-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/api/admin/{**catch-all}" }
      },
      "oauth-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/auth/{**catch-all}" }
      },
      "message-route": {
        "ClusterId": "message-cluster",
        "Match": { "Path": "/api/messages/{**catch-all}" }
      },
      "room-route": {
        "ClusterId": "room-cluster",
        "Match": { "Path": "/api/rooms/{**catch-all}" }
      },
      "room-admin-route": {
        "ClusterId": "room-cluster",
        "Match": { "Path": "/api/admin/rooms/{**catch-all}" }
      },
      "notification-route": {
        "ClusterId": "notification-cluster",
        "Match": { "Path": "/api/notifications/{**catch-all}" }
      },
      "media-route": {
        "ClusterId": "media-cluster",
        "Match": { "Path": "/api/media/{**catch-all}" }
      },
      "hub-route": {
        "ClusterId": "presence-cluster",
        "Match": { "Path": "/hubs/chat/{**catch-all}" }
      },
      "notification-hub-route": {
        "ClusterId": "notification-cluster",
        "Match": { "Path": "/hubs/notifications/{**catch-all}" }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": { "d1": { "Address": "https://real-time-chat-application-1-7bdu.onrender.com" } }
      },
      "message-cluster": {
        "Destinations": { "d1": { "Address": "https://message-service-2rib.onrender.com" } }
      },
      "room-cluster": {
        "Destinations": { "d1": { "Address": "https://chat-room-service-mtqt.onrender.com" } }
      },
      "notification-cluster": {
        "Destinations": { "d1": { "Address": "https://notification-service-kxnb.onrender.com" } }
      },
      "media-cluster": {
        "Destinations": { "d1": { "Address": "https://media-service-l8bp.onrender.com" } }
      },
      "presence-cluster": {
        "Destinations": { "d1": { "Address": "https://presence-service.onrender.com" } }
      }
    }
  }
}